      "isDeleted": false,
      "boundElements": null,
      "updated": 1773104126641,
      "link": null,
      "locked": false,
      "text": "– сложные выборки\n– сортировки\n– полнотекстовый поиск\n– реляционные связи (публикации ↔ комментарии ↔ лайки ↔ теги)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "– сложные выборки\n– сортировки\n– полнотекстовый поиск\n– реляционные связи (публикации ↔ комментарии ↔ лайки ↔ теги)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Y2gPU0yR5L_3JpPTcuJAf",
      "type": "text",
      "x": 69.38935142521711,
      "y": 271.8698032877611,
      "width": 397.7797546386719,
      "height": 50,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
