      "versionNonce": 1652177322,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773106450306,
      "link": null,
      "locked": false,
      "text": "– простая документная модель\n– нет сложных связей между сущностями",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "– простая документная модель\n– нет сложных связей между сущностями",
      "autoResize": true,
      "lineHeight": 1.25
    },
